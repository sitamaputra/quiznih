# ─── Quiznih Spin Bot — Environment Variables ────────────────────────────────
# Copy file ini ke .env lalu isi nilainya
# cp spinbot.env.example .env

# Private key wallet backend (yang punya CELO untuk jalankan bot)
# Tanpa prefix 0x juga bisa
PRIVATE_KEY=your_private_key_here

# Address SpinWheel contract (jangan diubah)
SPIN_WHEEL_PROXY_ADDRESS=0xAF67eE83Af8963516Eab2F53Ad5b22AB0a705117

# Network: true = Celo Mainnet, false = Celo Sepolia testnet
IS_MAINNET=true
