# Wallet yang dipakai untuk fund bot (harus punya CELO)
FUNDER_PRIVATE_KEY=0x...

# SpinWheel contract address setelah deploy
SPIN_WHEEL_ADDRESS=0x...

# Session UUID dari Supabase (dibuat via createSession() dulu)
SPIN_SESSION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Frontend/backend URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Jumlah bot yang dijalankan
BOT_COUNT=10

# Gas money per bot (0.001 CELO biasanya cukup)
# Bot tidak perlu banyak — hanya untuk 1-2 TX saja
GAS_FUND_PER_BOT_ETH=0.001

# Prize per spin dalam wei
# 0.0001 CELO = 100000000000000
PRIZE_AMOUNT_WEI=100000000000000

# Jeda antar bot dalam milidetik (biar natural)
BOT_DELAY_MS=3000
